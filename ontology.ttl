@prefix : <https://annosaxfdm.de/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://annosaxfdm.de/ontology/> .

<https://annosaxfdm.de/ontology/> rdf:type owl:Ontology ;
                                   <http://purl.org/dc/terms/abstract> "The Anthropological Notation Ontology (ANNO) allows the systematic and standardized classification of recovered bone finds into the skeletal system, the description of the skeletal pieces, and the definition of functions for the derivation of different phenotypes of humans in forensic and historical anthropology. ANNO consists of two components: ANNOdc, a domain-core ontology providing core entities such as basic anatomical categories, and ANNOds, a domain-specific ontology used for annotating structures of the human skeleton. ANNO is integrated into AnthroWorks3D, a photogrammetry pipeline and application for the creation and analysis of 3D-models of human skeletal remains. The integration is based on the three-ontology method with the General Formal Ontology as the top-level ontology, ANNOdc as the task ontology and ANNOds as the domain ontology. Thus, AnthroWorks3D only needs to implement access to the entities (classes and properties) of the task ontology, whereas the entities of the corresponding domain ontology are imported dynamically. ANNO supports the analysis of skeletal and bone finds in forensic and historical anthropology, facilitating the standardization of data annotation and ensuring accurate preservation of information for posterity."@en ;
                                   <http://purl.org/dc/terms/contributor> "Andy Ludwig" ,
                                                                          "Marleen Mohaupt" ;
                                   <http://purl.org/dc/terms/created> "2023-08-24"^^xsd:date ;
                                   <http://purl.org/dc/terms/creator> "<a href='https://github.com/KonradHoeffner'>Konrad Höffner</a>, <a href='https://www.imise.uni-leipzig.de/en'>IMISE Leipzig, Germany</a>" ,
                                                                      "<a href='https://www.cb.hs-mittweida.de/mitarbeiterinnen-mitarbeiter-in-ihren-fachgruppen/heuschkel-marie-luise/'>Marie Heuschkel</a>, <a href='https://www.cb.hs-mittweida.de/'>Hochschule Mittweida, Germany</a>" ,
                                                                      "<a href='https://www.cb.hs-mittweida.de/professoren-innen/forensik/prof-labudde/'>Dirk Labudde</a>, <a href='https://www.cb.hs-mittweida.de/'>Hochschule Mittweida, Germany</a>" ,
                                                                      "<a href='https://www.imise.uni-leipzig.de/en/Mitarbeiter/Alexandr_Uciteli'>Alexandr Uciteli</a>, <a href='https://www.imise.uni-leipzig.de/en'>IMISE Leipzig, Germany</a>" ,
                                                                      "Fabian Schmiedel" ;
                                   <http://purl.org/dc/terms/description> "The Anthropological Notation Ontology (ANNO) allows the systematic and standardized classification of recovered bone finds into the skeletal system, the description of the skeletal pieces, and the definition of functions for the derivation of different phenotypes of humans in forensic and historical anthropology."@en ,
                                                                          "Ziel des SaxFDM-Fokusprojektes ist die Entwicklung einer Ontologie für die einheitliche Einordnung der Knochenfunde aus den Ausgrabungen in das Skelettsystem, die Beschreibung der Skelettstücke sowie die Definition von Funktionen zur Ableitung verschiedener Phänotypen des Menschen. Die Ontologie soll in einem Terminologieservice verwaltet werden, der sich mit denen der NFDI synchronisieren kann."@de ;
                                   <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                   <http://purl.org/dc/terms/publisher> <https://www.imise.uni-leipzig.de> ;
                                   <http://purl.org/dc/terms/title> "The ANthropological Notation Ontology (ANNO): A core ontology for annotating human bones and deriving phenotypes"@en ;
                                   <http://purl.org/ontology/bibo/status> <http://purl.org/ontology/bibo/status/published> ;
                                   <http://purl.org/vocab/vann/preferredNamespacePrefix> "anno" ;
                                   <http://purl.org/vocab/vann/preferredNamespaceURI> "https://annosaxfdm.de/ontology/" ;
                                   <http://usefulinc.com/ns/doap#repository> <https://github.com/annosaxfdm/ontology> ;
                                   rdfs:label "Anthropological Notation Ontology"@en ;
                                   rdfs:seeAlso <https://ols.imise.uni-leipzig.de/ontologies/anno> ,
                                                <https://zenodo.org/record/8380382> ;
                                   owl:versionInfo "2024-02-15" ;
                                   <http://xmlns.com/foaf/0.1/homepage> "https://annosaxfdm.de/" ;
                                   <http://xmlns.com/foaf/0.1/logo> "https://annosaxfdm.imise.uni-leipzig.de/public/anno-logo-blue.svg" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
<http://purl.org/dc/terms/abstract> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/ontology/bibo/status
<http://purl.org/ontology/bibo/status> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceURI
<http://purl.org/vocab/vann/preferredNamespaceURI> rdf:type owl:AnnotationProperty .


###  http://usefulinc.com/ns/doap#repository
<http://usefulinc.com/ns/doap#repository> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
<http://www.w3.org/2004/02/skos/core#exactMatch> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#related
<http://www.w3.org/2004/02/skos/core#related> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/homepage
<http://xmlns.com/foaf/0.1/homepage> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/logo
<http://xmlns.com/foaf/0.1/logo> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.onto-med.de/ontologies/gfo.owl#boundaryOf
<http://www.onto-med.de/ontologies/gfo.owl#boundaryOf> rdf:type owl:ObjectProperty .


###  http://www.onto-med.de/ontologies/gfo.owl#hasBoundary
<http://www.onto-med.de/ontologies/gfo.owl#hasBoundary> rdf:type owl:ObjectProperty .


###  http://www.onto-med.de/ontologies/gfo.owl#hasPart
<http://www.onto-med.de/ontologies/gfo.owl#hasPart> rdf:type owl:ObjectProperty .


###  http://www.onto-med.de/ontologies/gfo.owl#occupiedBy
<http://www.onto-med.de/ontologies/gfo.owl#occupiedBy> rdf:type owl:ObjectProperty .


###  http://www.onto-med.de/ontologies/gfo.owl#occupies
<http://www.onto-med.de/ontologies/gfo.owl#occupies> rdf:type owl:ObjectProperty .


###  http://www.onto-med.de/ontologies/gfo.owl#partOf
<http://www.onto-med.de/ontologies/gfo.owl#partOf> rdf:type owl:ObjectProperty .


###  http://www.onto-med.de/ontologies/gfo.owl#propertyOf
<http://www.onto-med.de/ontologies/gfo.owl#propertyOf> rdf:type owl:ObjectProperty .


###  https://annosaxfdm.de/ontology/derivedFrom
:derivedFrom rdf:type owl:ObjectProperty ;
             rdfs:domain :Phenotype ;
             rdfs:range [ rdf:type owl:Class ;
                          owl:unionOf ( :AnatomicalEntity
                                        :AnatomicalProperty
                                      )
                        ] .


###  https://annosaxfdm.de/ontology/directionOf
:directionOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :locationOf ;
             owl:inverseOf :hasDirection .


###  https://annosaxfdm.de/ontology/endsOn
:endsOn rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf <http://www.onto-med.de/ontologies/gfo.owl#hasBoundary> ;
        rdfs:domain :AnatomicalLine ;
        rdfs:range :AnatomicalPoint .


###  https://annosaxfdm.de/ontology/hasDirection
:hasDirection rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :hasLocation .


###  https://annosaxfdm.de/ontology/hasLocation
:hasLocation rdf:type owl:ObjectProperty ;
             owl:inverseOf :locationOf ;
             rdfs:domain :AnatomicalEntity ;
             rdfs:range :RelativeAnatomicalLocation .


###  https://annosaxfdm.de/ontology/locatedOn
:locatedOn rdf:type owl:ObjectProperty ;
           rdfs:domain :ToothStructure ;
           rdfs:range :BoneStructure .


###  https://annosaxfdm.de/ontology/locationOf
:locationOf rdf:type owl:ObjectProperty ;
            rdfs:domain :RelativeAnatomicalLocation ;
            rdfs:range :AnatomicalEntity .


###  https://annosaxfdm.de/ontology/passesThrough
:passesThrough rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf <http://www.onto-med.de/ontologies/gfo.owl#hasBoundary> ;
               rdfs:domain :AnatomicalLine ;
               rdfs:range :AnatomicalPoint .


###  https://annosaxfdm.de/ontology/relativeTo
:relativeTo rdf:type owl:ObjectProperty ;
            rdfs:domain :RelativeAnatomicalLocation ;
            rdfs:range :AnatomicalEntity .


###  https://annosaxfdm.de/ontology/spatialEntityOf
:spatialEntityOf rdf:type owl:ObjectProperty ;
                 rdfs:domain :SpatialAnatomicalEntity ;
                 rdfs:range :AnatomicalStructure .


###  https://annosaxfdm.de/ontology/startsOn
:startsOn rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf <http://www.onto-med.de/ontologies/gfo.owl#hasBoundary> ;
          rdfs:domain :AnatomicalLine ;
          rdfs:range :AnatomicalPoint .


#################################################################
#    Data properties
#################################################################

###  https://annosaxfdm.de/ontology/hasValue
:hasValue rdf:type owl:DatatypeProperty ;
          rdfs:domain :SpatialAnatomicalEntity ;
          rdfs:range xsd:decimal .


#################################################################
#    Classes
#################################################################

###  http://www.onto-med.de/ontologies/gfo.owl#Attributive
<http://www.onto-med.de/ontologies/gfo.owl#Attributive> rdf:type owl:Class .


###  http://www.onto-med.de/ontologies/gfo.owl#LineRegion
<http://www.onto-med.de/ontologies/gfo.owl#LineRegion> rdf:type owl:Class .


###  http://www.onto-med.de/ontologies/gfo.owl#MaterialObject
<http://www.onto-med.de/ontologies/gfo.owl#MaterialObject> rdf:type owl:Class .


###  http://www.onto-med.de/ontologies/gfo.owl#PointRegion
<http://www.onto-med.de/ontologies/gfo.owl#PointRegion> rdf:type owl:Class .


###  http://www.onto-med.de/ontologies/gfo.owl#Relator
<http://www.onto-med.de/ontologies/gfo.owl#Relator> rdf:type owl:Class .


###  http://www.onto-med.de/ontologies/gfo.owl#SpaceEntity
<http://www.onto-med.de/ontologies/gfo.owl#SpaceEntity> rdf:type owl:Class .


###  http://www.onto-med.de/ontologies/gfo.owl#SpaceRegion
<http://www.onto-med.de/ontologies/gfo.owl#SpaceRegion> rdf:type owl:Class .


###  http://www.onto-med.de/ontologies/gfo.owl#SurfaceRegion
<http://www.onto-med.de/ontologies/gfo.owl#SurfaceRegion> rdf:type owl:Class .


###  https://annosaxfdm.de/ontology/AnatomicalAxis
:AnatomicalAxis rdf:type owl:Class ;
                rdfs:subClassOf :AnatomicalLine ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasDirection ;
                                  owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                  owl:onClass :RelativeAnatomicalLocation
                                ] ;
                rdfs:comment "Anatomical axes are lines around which an organism is approximately symmetrical."@en ;
                rdfs:label "Anatomical axis"@en .


###  https://annosaxfdm.de/ontology/AnatomicalEntity
:AnatomicalEntity rdf:type owl:Class ;
                  rdfs:comment "An anatomical entity is either an anatomical structure or a spatial anatomical entity."@en ;
                  rdfs:label "Anatomical entity"@en ;
                  <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/sig/ont/fma/fma61775> .


###  https://annosaxfdm.de/ontology/AnatomicalLine
:AnatomicalLine rdf:type owl:Class ;
                rdfs:subClassOf <http://www.onto-med.de/ontologies/gfo.owl#LineRegion> ,
                                :SpatialAnatomicalEntity ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#boundaryOf> ;
                                  owl:someValuesFrom :AnatomicalSurface
                                ] ;
                rdfs:comment "An anatomical line is a boundary (one-dimensional) of an anatomical surface."@en ,
                             "An anatomical line is a conceptual, immaterial line on a bone that passes between or at multiple measurement points and is used in the form of distances, circumferences, or angles to collect measurements representing aspects of the bone’s dimensions."@en ,
                             "Anatomical lines can connect or pass through points on anatomical entities (e.g., an edge between two or an angle between three anatomical entities)."@en ;
                rdfs:label "Anatomical line"@en ;
                <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/sig/ont/fma/fma9657> .


###  https://annosaxfdm.de/ontology/AnatomicalPlane
:AnatomicalPlane rdf:type owl:Class ;
                 rdfs:subClassOf :AnatomicalSurface ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#hasBoundary> ;
                                   owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                   owl:onClass :AnatomicalAxis
                                 ] ;
                 rdfs:comment "An anatomical plane is a hypothetical plane that transects the body to describe the location of structures or the direction of movements."@en ;
                 rdfs:label "Anatomical plane"@en ;
                 <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/sig/ont/fma/fma242982> .


###  https://annosaxfdm.de/ontology/AnatomicalPoint
:AnatomicalPoint rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.onto-med.de/ontologies/gfo.owl#PointRegion> ,
                                 :SpatialAnatomicalEntity ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#boundaryOf> ;
                                   owl:someValuesFrom :AnatomicalLine
                                 ] ;
                 rdfs:comment "An anatomical point is a boundary (zero-dimensional) of an anatomical line."@en ,
                              "An osteometric landmark or anatomical point is any immaterial, conceptual point that marks a location on a bone, either to create measurements (anatomical lines) or align the bone in specific planes for a measurement. The former serve as measurement points, the latter as orientation points."@en ;
                 rdfs:label "Anatomical point"@en ;
                 <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/sig/ont/fma/fma9658> .


###  https://annosaxfdm.de/ontology/AnatomicalProperty
:AnatomicalProperty rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.onto-med.de/ontologies/gfo.owl#Attributive> ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#propertyOf> ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass :AnatomicalStructure
                                    ] ;
                    rdfs:comment "An anatomical property is a characteristic (e.g., shape) of an anatomical structure."@en ;
                    rdfs:label "Anatomical property"@en .


###  https://annosaxfdm.de/ontology/AnatomicalSpace
:AnatomicalSpace rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.onto-med.de/ontologies/gfo.owl#SpaceRegion> ,
                                 :SpatialAnatomicalEntity ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#occupiedBy> ;
                                   owl:someValuesFrom :AnatomicalStructure
                                 ] ;
                 rdfs:comment "An anatomical space is a space region (three-dimensional) occupied by a material anatomical object."@en ;
                 rdfs:label "Anatomical space"@en .


###  https://annosaxfdm.de/ontology/AnatomicalStructure
:AnatomicalStructure rdf:type owl:Class ;
                     rdfs:subClassOf <http://www.onto-med.de/ontologies/gfo.owl#MaterialObject> ,
                                     :AnatomicalEntity ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#occupies> ;
                                       owl:someValuesFrom :AnatomicalSpace
                                     ] ;
                     rdfs:comment "Anatomical structures in the anthropological context are material anatomical entities: tooth structures (teeth and teeth parts), bone structures (single bones, bone parts and bone compounds), as well as the complete skeleton."@en ;
                     rdfs:label "Anatomical structure"@en ;
                     <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/sig/ont/fma/fma67165> .


###  https://annosaxfdm.de/ontology/AnatomicalSurface
:AnatomicalSurface rdf:type owl:Class ;
                   rdfs:subClassOf <http://www.onto-med.de/ontologies/gfo.owl#SurfaceRegion> ,
                                   :SpatialAnatomicalEntity ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#boundaryOf> ;
                                     owl:someValuesFrom :AnatomicalSpace
                                   ] ;
                   rdfs:comment "An anatomical surface is a boundary (two-dimensional) of an anatomical space."@en ;
                   rdfs:label "Anatomical surface"@en ;
                   <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/sig/ont/fma/fma24137> .


###  https://annosaxfdm.de/ontology/Bone
:Bone rdf:type owl:Class ;
      rdfs:subClassOf :BoneStructure ;
      rdfs:comment "A bone is a skeletal element, i.e. a single self-contained bony entity. Bones, such as Radius and Ulna are individual bone organs."@en ;
      rdfs:label "Bone"@en ;
      <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/sig/ont/fma/fma5018> .


###  https://annosaxfdm.de/ontology/BoneCompound
:BoneCompound rdf:type owl:Class ;
              rdfs:subClassOf :BoneStructure ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#hasPart> ;
                                owl:someValuesFrom [ rdf:type owl:Class ;
                                                     owl:unionOf ( :Bone
                                                                   :BoneCompound
                                                                   :BonePart
                                                                 )
                                                   ]
                              ] ;
              rdfs:comment "A bone compound is a composite structure consisting of further bone compounds, individual bones or bone parts."@en ,
                           "A bone compound is a section of the skeleton combining multiple bones or bone parts together, depending on the classification system chosen. This allows for the representation of any partonomy that need not necessarily be compatible with one another."@en ;
              rdfs:label "Bone compound"@en ;
              <http://www.w3.org/2004/02/skos/core#related> <http://purl.org/sig/ont/fma/fma23881> ,
                                                            <http://purl.org/sig/ont/fma/fma85544> .


###  https://annosaxfdm.de/ontology/BonePart
:BonePart rdf:type owl:Class ;
          rdfs:subClassOf :BoneStructure ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#partOf> ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Bone
                          ] ;
          rdfs:comment "A bone part is a part of a single bone (e.g., bony processes or bony prominences)."@en ,
                       "An anatomical landmark is any distinct structure on a bone. In ANNO, it is also referred to as a 'bone part'."@en ,
                       "On the skeletal level, bone parts comprise any piece or portion of a bone."@en ;
          rdfs:label "Bone part"@en ;
          <http://www.w3.org/2004/02/skos/core#related> <http://purl.org/sig/ont/fma/fma10483> ,
                                                        <http://purl.org/sig/ont/fma/fma281808> .


###  https://annosaxfdm.de/ontology/BoneStructure
:BoneStructure rdf:type owl:Class ;
               rdfs:subClassOf :AnatomicalStructure ;
               rdfs:comment "A bone structure is either a single bone or a bone part or a bone compound."@en ,
                            "Bone structures comprise all possible parts of the human skeleton, which are individual bones, bone parts, bone compounds as well as the complete skeleton excluding the teeth."@en ;
               rdfs:label "Bone structure"@en .


###  https://annosaxfdm.de/ontology/MeasurementPoint
:MeasurementPoint rdf:type owl:Class ;
                  rdfs:subClassOf :AnatomicalPoint ;
                  rdfs:label "Measurement point"@en .


###  https://annosaxfdm.de/ontology/OrientationPoint
:OrientationPoint rdf:type owl:Class ;
                  rdfs:subClassOf :AnatomicalPoint ;
                  rdfs:label "Orientation point"@en .


###  https://annosaxfdm.de/ontology/Phenotype
:Phenotype rdf:type owl:Class ;
           rdfs:subClassOf <http://www.onto-med.de/ontologies/gfo.owl#Attributive> ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :derivedFrom ;
                             owl:someValuesFrom [ rdf:type owl:Class ;
                                                  owl:unionOf ( :AnatomicalEntity
                                                                :AnatomicalProperty
                                                              )
                                                ]
                           ] ;
           rdfs:comment "A phenotype is a (combination of) bodily feature(s) or observable characteristic(s) of an organism."@en ;
           rdfs:label "Phenotype"@en .


###  https://annosaxfdm.de/ontology/RelativeAnatomicalLocation
:RelativeAnatomicalLocation rdf:type owl:Class ;
                            rdfs:subClassOf <http://www.onto-med.de/ontologies/gfo.owl#Relator> ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :locationOf ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass :AnatomicalEntity
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :relativeTo ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onClass :AnatomicalEntity
                                            ] ;
                            rdfs:comment "A relative anatomical location is a position of an anatomical entity (e.g., a bone object) in relation to another anatomical entity (e.g., another bone, an axis, a plane or a point such as the centre of the body). Relative anatomical locations are classified according to the anatomical terms of location (e.g., cranial = 'towards the end of the skull' or dexter = 'right')."@en ,
                                         "The position of all anatomical structures is described in a standardised fashion using conceptual axes (a kind of anatomical lines), planes (a kind of anatomical surfaces) as well as directions (relative anatomical locations) relative to the body based on the standard anatomical position which refers to standing upright, facing forward, palms and toes pointing forward, thumbs to the side, and observed from the perspective of the respective individual."@en ;
                            rdfs:label "Relative anatomical location"@en ;
                            <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/sig/ont/fma/fma30346> .


###  https://annosaxfdm.de/ontology/Skeleton
:Skeleton rdf:type owl:Class ;
          rdfs:subClassOf :AnatomicalStructure ,
                          [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                   owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#hasPart> ;
                                                   owl:someValuesFrom :BoneStructure
                                                 ]
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#hasPart> ;
                                                   owl:someValuesFrom :ToothStructure
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
          rdfs:comment "The largest or most comprehensive anatomical structure, the human skeleton is the framework composed of all the bones and the teeth of a human being."@en ;
          rdfs:label "Skeleton"@en .


###  https://annosaxfdm.de/ontology/SpatialAnatomicalEntity
:SpatialAnatomicalEntity rdf:type owl:Class ;
                         rdfs:subClassOf <http://www.onto-med.de/ontologies/gfo.owl#SpaceEntity> ,
                                         :AnatomicalEntity ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :spatialEntityOf ;
                                           owl:someValuesFrom :AnatomicalStructure
                                         ] ;
                         rdfs:comment "A spatial anatomical entity is either an anatomical space (three-dimensional) or an anatomical surface (two-dimensional) or an anatomical line (one-dimensional) or an anatomical point (zero-dimensional)."@en ,
                                      "An (immaterial) anatomical entity without mass is classified as a spatial anatomical entity."@en ;
                         rdfs:label "Spatial anatomical entity"@en ;
                         <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/sig/ont/fma/fma67112> .


###  https://annosaxfdm.de/ontology/Tooth
:Tooth rdf:type owl:Class ;
       rdfs:subClassOf :ToothStructure ;
       rdfs:comment "A human tooth is the individual entity of the human dentition or the teeth as a whole. Teeth are parts of the skeleton, yet they are characterised by their own distinctive tissue and thus treated separately from bones. Teeth, such as the Dens caninus (canine tooth) are located on bone structures."@en ;
       rdfs:label "Tooth"@en ;
       <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/sig/ont/fma/fma12516> .


###  https://annosaxfdm.de/ontology/ToothPart
:ToothPart rdf:type owl:Class ;
           rdfs:subClassOf :ToothStructure ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty <http://www.onto-med.de/ontologies/gfo.owl#partOf> ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Tooth
                           ] ;
           rdfs:comment "A tooth part is a part of a single tooth."@en ;
           rdfs:label "Tooth part"@en .


###  https://annosaxfdm.de/ontology/ToothStructure
:ToothStructure rdf:type owl:Class ;
                rdfs:subClassOf :AnatomicalStructure ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :locatedOn ;
                                  owl:someValuesFrom :BoneStructure
                                ] ;
                rdfs:comment "A tooth structure is either a single tooth or a tooth part."@en ;
                rdfs:label "Tooth structure"@en .


