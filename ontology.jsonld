  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An anatomical entity is either an anatomical structure or a spatial anatomical entity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Anatomical entity"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma61775"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/AnatomicalLine",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An anatomical line is a boundary (one-dimensional) of an anatomical surface."
  }, {
    "@language" : "en",
    "@value" : "An anatomical line is a conceptual, immaterial line on a bone that passes between or at multiple measurement points and is used in the form of distances, circumferences, or angles to collect measurements representing aspects of the bone’s dimensions."
  }, {
    "@language" : "en",
    "@value" : "Anatomical lines can connect or pass through points on anatomical entities (e.g., an edge between two or an angle between three anatomical entities)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Anatomical line"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.onto-med.de/ontologies/gfo.owl#LineRegion"
  }, {
    "@id" : "https://annosaxfdm.de/ontology/SpatialAnatomicalEntity"
  }, {
    "@id" : "_:genid5"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma9657"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/AnatomicalPlane",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An anatomical plane is a hypothetical plane that transects the body to describe the location of structures or the direction of movements."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Anatomical plane"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalSurface"
  }, {
    "@id" : "_:genid6"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma242982"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/AnatomicalPoint",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An anatomical point is a boundary (zero-dimensional) of an anatomical line."
  }, {
    "@language" : "en",
    "@value" : "An osteometric landmark or anatomical point is any immaterial, conceptual point that marks a location on a bone, either to create measurements (anatomical lines) or align the bone in specific planes for a measurement. The former serve as measurement points, the latter as orientation points."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Anatomical point"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.onto-med.de/ontologies/gfo.owl#PointRegion"
  }, {
    "@id" : "https://annosaxfdm.de/ontology/SpatialAnatomicalEntity"
  }, {
    "@id" : "_:genid7"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma9658"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/AnatomicalProperty",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An anatomical property is a characteristic (e.g., shape) of an anatomical structure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Anatomical property"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.onto-med.de/ontologies/gfo.owl#Attributive"
  }, {
    "@id" : "_:genid8"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/AnatomicalSpace",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An anatomical space is a space region (three-dimensional) occupied by a material anatomical object."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Anatomical space"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.onto-med.de/ontologies/gfo.owl#SpaceRegion"
  }, {
    "@id" : "https://annosaxfdm.de/ontology/SpatialAnatomicalEntity"
  }, {
    "@id" : "_:genid9"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/AnatomicalStructure",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Anatomical structures in the anthropological context are material anatomical entities: tooth structures (teeth and teeth parts), bone structures (single bones, bone parts and bone compounds), as well as the complete skeleton."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Anatomical structure"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.onto-med.de/ontologies/gfo.owl#MaterialObject"
  }, {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalEntity"
  }, {
    "@id" : "_:genid10"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma67165"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/AnatomicalSurface",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An anatomical surface is a boundary (two-dimensional) of an anatomical space."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Anatomical surface"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.onto-med.de/ontologies/gfo.owl#SurfaceRegion"
  }, {
    "@id" : "https://annosaxfdm.de/ontology/SpatialAnatomicalEntity"
  }, {
    "@id" : "_:genid11"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma24137"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/Bone",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A bone is a skeletal element, i.e. a single self-contained bony entity. Bones, such as Radius and Ulna are individual bone organs."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Bone"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/BoneStructure"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma5018"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/BoneCompound",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A bone compound is a composite structure consisting of further bone compounds, individual bones or bone parts."
  }, {
    "@language" : "en",
    "@value" : "A bone compound is a section of the skeleton combining multiple bones or bone parts together, depending on the classification system chosen. This allows for the representation of any partonomy that need not necessarily be compatible with one another."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Bone compound"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/BoneStructure"
  }, {
    "@id" : "_:genid12"
  } ],
  "http://www.w3.org/2004/02/skos/core#related" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma23881"
  }, {
    "@id" : "http://purl.org/sig/ont/fma/fma85544"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/BonePart",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A bone part is a part of a single bone (e.g., bony processes or bony prominences)."
  }, {
    "@language" : "en",
    "@value" : "An anatomical landmark is any distinct structure on a bone. In ANNO, it is also referred to as a 'bone part'."
  }, {
    "@language" : "en",
    "@value" : "On the skeletal level, bone parts comprise any piece or portion of a bone."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Bone part"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/BoneStructure"
  }, {
    "@id" : "_:genid17"
  } ],
  "http://www.w3.org/2004/02/skos/core#related" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma10483"
  }, {
    "@id" : "http://purl.org/sig/ont/fma/fma281808"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/BoneStructure",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A bone structure is either a single bone or a bone part or a bone compound."
  }, {
    "@language" : "en",
    "@value" : "Bone structures comprise all possible parts of the human skeleton, which are individual bones, bone parts, bone compounds as well as the complete skeleton excluding the teeth."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Bone structure"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalStructure"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/MeasurementPoint",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Measurement point"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalPoint"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/OrientationPoint",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Orientation point"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalPoint"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/Phenotype",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A phenotype is a (combination of) bodily feature(s) or observable characteristic(s) of an organism."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Phenotype"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.onto-med.de/ontologies/gfo.owl#Attributive"
  }, {
    "@id" : "_:genid18"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/RelativeAnatomicalLocation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A relative anatomical location is a position of an anatomical entity (e.g., a bone object) in relation to another anatomical entity (e.g., another bone, an axis, a plane or a point such as the centre of the body). Relative anatomical locations are classified according to the anatomical terms of location (e.g., cranial = 'towards the end of the skull' or dexter = 'right')."
  }, {
    "@language" : "en",
    "@value" : "The position of all anatomical structures is described in a standardised fashion using conceptual axes (a kind of anatomical lines), planes (a kind of anatomical surfaces) as well as directions (relative anatomical locations) relative to the body based on the standard anatomical position which refers to standing upright, facing forward, palms and toes pointing forward, thumbs to the side, and observed from the perspective of the respective individual."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Relative anatomical location"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.onto-med.de/ontologies/gfo.owl#Relator"
  }, {
    "@id" : "_:genid22"
  }, {
    "@id" : "_:genid23"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma30346"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/Skeleton",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The largest or most comprehensive anatomical structure, the human skeleton is the framework composed of all the bones and the teeth of a human being."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Skeleton"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalStructure"
  }, {
    "@id" : "_:genid24"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/SpatialAnatomicalEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A spatial anatomical entity is either an anatomical space (three-dimensional) or an anatomical surface (two-dimensional) or an anatomical line (one-dimensional) or an anatomical point (zero-dimensional)."
  }, {
    "@language" : "en",
    "@value" : "An (immaterial) anatomical entity without mass is classified as a spatial anatomical entity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Spatial anatomical entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.onto-med.de/ontologies/gfo.owl#SpaceEntity"
  }, {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalEntity"
  }, {
    "@id" : "_:genid29"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma67112"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/Tooth",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A human tooth is the individual entity of the human dentition or the teeth as a whole. Teeth are parts of the skeleton, yet they are characterised by their own distinctive tissue and thus treated separately from bones. Teeth, such as the Dens caninus (canine tooth) are located on bone structures."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Tooth"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/ToothStructure"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.org/sig/ont/fma/fma12516"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/ToothPart",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A tooth part is a part of a single tooth."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Tooth part"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/ToothStructure"
  }, {
    "@id" : "_:genid30"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/ToothStructure",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A tooth structure is either a single tooth or a tooth part."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Tooth structure"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalStructure"
  }, {
    "@id" : "_:genid31"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/derivedFrom",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://annosaxfdm.de/ontology/Phenotype"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid1"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/directionOf",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/locationOf"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/hasDirection"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/endsOn",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalLine"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalPoint"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.onto-med.de/ontologies/gfo.owl#hasBoundary"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/hasDirection",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/hasLocation"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/hasLocation",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://annosaxfdm.de/ontology/AnatomicalEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://annosaxfdm.de/ontology/RelativeAnatomicalLocation"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://annosaxfdm.de/ontology/locationOf"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/hasValue",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://annosaxfdm.de/ontology/SpatialAnatomicalEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ]
}, {
  "@id" : "https://annosaxfdm.de/ontology/locatedOn",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://annosaxfdm.de/ontology/ToothStructure"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://annosaxfdm.de/ontology/BoneStructure"
  } ]
